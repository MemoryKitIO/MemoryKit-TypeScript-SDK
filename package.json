{
  "name": "memorykit",
  "version": "0.1.1",
  "description": "Official TypeScript SDK for MemoryKit — memory infrastructure for AI applications",
  "author": "MemoryKit",
  "license": "MIT",
  "homepage": "https://memorykit.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/MemoryKitIO/memorykit-typescript-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/MemoryKitIO/memorykit-typescript-sdk/issues"
  },
  "keywords": [
    "memorykit",
    "ai",
    "memory",
    "rag",
    "embeddings",
    "vector-search",
    "knowledge-base",
    "llm",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc --project tsconfig.json",
    "build:cjs": "tsc --project tsconfig.cjs.json && node scripts/fix-cjs.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
